## Backend environment variables (example)
## Copy this file to `.env` and update values.

# MongoDB connection string (Atlas example)
# 1) Create a cluster on MongoDB Atlas
# 2) Add a database user + allow your IP (Network Access)
# 3) Copy the connection string here
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/vartalap_chat?retryWrites=true&w=majority

# Local MongoDB alternative
# MONGODB_URI=mongodb://127.0.0.1:27017/vartalap_chat

# Server port
PORT=4000

# JWT secret for signing tokens (use a long random string in production)
JWT_SECRET=change_me_to_a_long_random_secret

# Optional (used for documentation/deployment)
FRONTEND_URL=http://localhost:5173
